# AI Providers
# ============

# OpenAI API Key (GPT-5.1 for chat, text-embedding-3-small for RAG)
OPENAI_API_KEY=sk-xxxxx

# Anthropic Claude API Key (Claude Sonnet for chat)
ANTHROPIC_API_KEY=sk-ant-xxxxx

# AI Provider Configuration
# -------------------------
# Default AI provider for chat (openai | claude)
# If not set, defaults to 'claude' when ANTHROPIC_API_KEY is available
AI_PROVIDER=claude

# External Services
# =================

# SBYN API (for status page)
SBYN_BASE_URL=https://example.com
SBYN_TOKEN=xxxxx
